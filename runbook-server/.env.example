# runbook-server local-dev env. Copy to .env and edit as needed.
#   cp runbook-server/.env.example runbook-server/.env
# Values below pair with the default compose stack (docker compose up -d).

# ---------- Runtime ----------
ENV=local
# Must match WORKFLOW_SERVER_URL port in app/.env.example (http://127.0.0.1:8002).
API_PORT=8002

# ---------- Database ----------
# runbook-server uses its own DSN env (AUTO_PILOT_DATABASE_URL — legacy name
# kept for compatibility; the service is runbook-server, not auto-pilot).
# Reuses the compose Postgres / SaaS DB.
AUTO_PILOT_DATABASE_URL=postgresql://postgres:postgrespassword@127.0.0.1:5432/nudgebee?sslmode=disable

# ---------- Secrets ----------
# MUST be identical to NUDGEBEE_ENCRYPTION_KEY in api-server/services/.env.
NUDGEBEE_ENCRYPTION_KEY=__REPLACE__

# Optional internal-action token. Default empty on both sides disables the
# check. Set to match api-server/services/.env if you turn it on there.
# ACTION_API_SERVER_TOKEN=

# ---------- Temporal ----------
# gRPC endpoint for the Temporal server used by workflow execution.
TEMPORAL_GRPC_ENDPOINT=127.0.0.1:7233

# ---------- RabbitMQ ----------
# Defaults match the rabbitmq:3-management container in docker-compose.yaml.
RABBIT_MQ_HOST=127.0.0.1
RABBIT_MQ_PORT=5672
RABBIT_MQ_USERNAME=guest
RABBIT_MQ_PASSWORD=guest

# ---------- Downstream services ----------
# Ports match app/.env.example canonical local-dev map.
SERVICE_API_SERVER_URL=http://127.0.0.1:8000
LLM_SERVER_URL=http://127.0.0.1:8005
TICKET_SERVICE_URL=http://127.0.0.1:8004
NOTIFICATION_SERVICE_URL=http://127.0.0.1:8003
CLOUD_COLLECTOR_SERVER_URL=http://127.0.0.1:8001
RELAY_SERVER_ENDPOINT=http://127.0.0.1:8006
