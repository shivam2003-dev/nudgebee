# k8s-collector local-dev env. Copy to .env and edit as needed.
#   cp collector-server/k8s-collector/app/.env.example \
#      collector-server/k8s-collector/app/.env
# Values below pair with the default compose stack (docker compose up -d).
#
# k8s-collector uses pydantic-settings (BaseSettings) — fields without
# defaults are *required* and the process won't start if they're missing.

# ---------- Runtime profile ----------
# Selects config profile: PROD / DEV / DEBUG. Default PROD; DEV/DEBUG also
# expose the Flask-RESTX doc page at /.
ENV=DEV

# ---------- HTTP server ----------
# SERVICE_PORT defaults to 5000, SERVICE_HOST to 0.0.0.0. Override only
# if you have a port conflict.
# SERVICE_PORT=5000
# SERVICE_HOST=0.0.0.0

# ---------- Collector mode ----------
# Controls what this process collects. "both" runs the discovery
# consumer and the event consumer; restrict to one if you're isolating.
COLLECTOR_MODE=both

# ---------- Database ----------
# Compose Postgres credentials. Same DSN env the relay-server uses.
COLLECTOR_DB_URL=postgresql://postgres:postgrespassword@127.0.0.1:5432/nudgebee?sslmode=disable

# ---------- Secrets ----------
# AES key used to decrypt agent secrets stored in the DB by services-server.
# MUST be identical to NUDGEBEE_ENCRYPTION_KEY in api-server/services/.env —
# k8s-collector reads what services-server wrote.
NUDGEBEE_ENCRYPTION_KEY=__REPLACE__

# Shared token for internal service-to-service calls into services-server.
# Default is empty on both sides, which disables the check (fine for local
# dev). If set, MUST match ACTION_API_SERVER_TOKEN in api-server/services/.env.
ACTION_API_SERVER_TOKEN=

# ---------- RabbitMQ ----------
# Defaults match the rabbitmq:3-management container in docker-compose.yaml.
RABBIT_MQ_HOST=127.0.0.1
RABBIT_MQ_PORT=5672
RABBIT_MQ_USERNAME=guest
RABBIT_MQ_PASSWORD=guest

# Exchange/queue names have sensible defaults — set only to override.
# RABBIT_MQ_EVENT_EXCHANGE=k8s_agent_exchange
# RABBIT_MQ_EVENT_QUEUE=k8s_agent_events
# RABBIT_MQ_DISCOVERY_QUEUE=k8s_agent_discovery
# RABBIT_MQ_SPEND_QUEUE=k8s_agent_spend
# RABBIT_MQ_KG_UPDATE_EXCHANGE=kg_update_exchange
# RABBIT_MQ_KG_UPDATE_QUEUE=kg_update

# ---------- Redis ----------
# Compose ships a redis:7-alpine. Required by pydantic-settings even if
# unused — set to 127.0.0.1:6379 with empty credentials.
REDIS_SERVER_HOST=127.0.0.1
REDIS_SERVER_PORT=6379
REDIS_USER_NAME=
REDIS_USER_PASSWORD=

# ---------- ClickHouse ----------
# Not part of the OSS local stack. Keep CLICKHOUSE_ENABLED=false and
# leave the connection fields empty — pydantic accepts empty strings,
# the disabled flag short-circuits any actual connection attempt.
CLICKHOUSE_ENABLED=false
CLICKHOUSE_HOST=
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=

# ---------- Downstream services ----------
# Defaults point at compose service hostnames. Override for from-source
# local dev (where these run on 127.0.0.1:<port>).
# SERVICE_API_SERVER_URL=http://127.0.0.1:8000
# LLM_SERVER_ENDPOINT=http://127.0.0.1:8005
# AUTO_PILOT_URL=http://127.0.0.1:9988
