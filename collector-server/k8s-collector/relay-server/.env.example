# relay-server local-dev env. Copy to .env and edit as needed.
#   cp collector-server/k8s-collector/relay-server/.env.example \
#      collector-server/k8s-collector/relay-server/.env
# Values below pair with the default compose stack (docker compose up -d).

# ---------- Runtime ----------
# Must match RELAY_SERVER_ENDPOINT port in app/.env.example (http://127.0.0.1:8006).
# Viper key is http.port; env var is RELAY_HTTP_PORT (RELAY_ prefix applied by viper).
RELAY_HTTP_PORT=8006

# ---------- Database ----------
# Compose Postgres credentials. Relay-server uses its own DSN env
# (COLLECTOR_DB_URL) rather than APP_DATABASE_URL.
COLLECTOR_DB_URL=postgres://postgres:postgrespassword@127.0.0.1:5432/nudgebee?sslmode=disable

# ---------- Secrets ----------
# AES key used to decrypt agent secrets stored in the DB by services-server.
# MUST be identical to NUDGEBEE_ENCRYPTION_KEY in api-server/services/.env —
# relay-server reads what services-server wrote, so a mismatch yields
# undecodable agent rows.
NUDGEBEE_ENCRYPTION_KEY=__REPLACE__

# Static auth key for the X-SECRET-KEY header on /request, /grafana/*,
# /prometheus-v2/*, /ws, /api/proxy/*. The Go default is a dev sample
# string; the chart generates a random one. Generate fresh:
#   openssl rand -hex 32
# RELAY_SERVER_SECRET_KEY=

# ---------- RabbitMQ ----------
# Defaults match the rabbitmq:3-management container in docker-compose.yaml.
# Relay-server publishes RPC requests to per-tenant queues here.
RABBIT_MQ_HOST=127.0.0.1
RABBIT_MQ_USERNAME=guest
RABBIT_MQ_PASSWORD=guest
# RABBIT_MQ_PORT, RABBITMQ_EXCHANGE_NAME, RABBITMQ_REQUEST_QUEUE, and
# RABBITMQ_MESSAGE_TTL have sensible defaults — set only to override.

# ---------- Cache ----------
# Match prod code path (Redis) so local dev exercises the same store the
# 30-min agent-validation cache uses in production.
CACHE_PROVIDER=redis
REDIS_SERVER_HOST=127.0.0.1
REDIS_SERVER_PORT=6379

# REDIS_SERVER_HOST / REDIS_SERVER_PORT default to 127.0.0.1:6379.
# REDIS_USER_NAME / REDIS_USER_PASSWORD only needed for auth-enabled redis.

# ---------- Signing (optional) ----------
# Ed25519 keypair for message signing to proxy agents. Leave empty for
# local dev — signing is disabled when private key is empty (backward
# compatible). Generate via `openssl genpkey -algorithm ed25519` and
# base64-encode the raw private bytes.
# SIGNING_PRIVATE_KEY=
# SIGNING_KEY_ID=default

# ---------- OpenTelemetry (optional) ----------
# Default exporter is `noop` — nothing exported. Flip to `console` to see
# spans/metrics in stdout, or `otlp` if you have a local OTel collector.
# OTEL_EXPORTER=console
# OTEL_EXPORTER_OTLP_ENDPOINT=127.0.0.1:4317
