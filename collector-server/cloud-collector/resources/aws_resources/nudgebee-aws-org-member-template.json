                ]
            },
            "Description": "The ARN of the IAM role used by EventBridge to send events to Nudgebee SQS queue."
        },
        "AccountNumber": {
            "Value": {
                "Ref": "AWS::AccountId"
            },
            "Description": "The AWS Account ID of this member account."
        },
        "CurBucketName": {
            "Value": {
