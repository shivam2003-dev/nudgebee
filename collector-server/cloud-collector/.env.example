# cloud-collector local-dev env. Copy to .env and edit as needed.
#   cp collector-server/cloud-collector/.env.example \
#      collector-server/cloud-collector/.env
# Values below pair with the default compose stack (docker compose up -d).

# ---------- Runtime ----------
ENV=local
PORT=8001

# ---------- Database ----------
# cloud-collector uses its own DSN env (CLOUD_COLLECTOR_SERVER_DB_URL).
# Reuses the compose Postgres / SaaS DB.
CLOUD_COLLECTOR_SERVER_DB_URL=postgresql://postgres:postgrespassword@localhost:5432/nudgebee?sslmode=disable

# ---------- Secrets ----------
# MUST be identical to NUDGEBEE_ENCRYPTION_KEY in api-server/services/.env.
NUDGEBEE_ENCRYPTION_KEY=__REPLACE__

# Token validated on incoming requests from services-server. The chart
# generates a random one and shares it; for local dev a stable string is
# fine. Treat as a shared secret with services-server's clients.
CLOUD_COLLECTOR_SERVER_TOKEN=myadminsecretkey

# Optional internal-action token (for outbound calls into services-server).
# Default empty on both sides disables the check.
# ACTION_API_SERVER_TOKEN=

# ---------- Network ----------
SERVICE_API_SERVER_URL=http://localhost:8000
BASE_URL=http://localhost:3000

# ---------- RabbitMQ ----------
# Defaults match the rabbitmq:3-management container in docker-compose.yaml.
RABBIT_MQ_HOST=localhost
RABBIT_MQ_PORT=5672
RABBIT_MQ_USERNAME=guest
RABBIT_MQ_PASSWORD=guest

# Exchange/queue names have sensible defaults — set only to override.

# ---------- AWS access (optional, for local cloud-collector dev) ----------
# Set if you want to actually exercise AWS API calls against a real account.
# Leave unset for an OSS local stack that just runs the consumer loops.
# AWS_PROFILE=
# AWS_REGION=us-east-1

# ---------- Disabled components ----------
# ClickHouse is not part of the OSS local stack.
# CLICKHOUSE_ENABLED=false
