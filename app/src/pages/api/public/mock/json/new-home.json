            {
              "account_id": "ff87fbfd-5729-4474-b9d6-96beb693e3fd",
              "unique_id": "17",
              "title": "1 workload has Critical/High security vulnerabilities",
              "id": "691e7dec-550e-44a1-9e4f-5f7010203b29",
              "applications": null,
              "type": "Ops",
              "rule": {
                "type": "Ratio",
                "with": "WITH pod_container AS ( SELECT cr.workload_name AS workload_name, cr.workload_type AS workload_type, cr.\"namespace\" AS \"namespace\", cr.cloud_account_id AS cloud_account_id, container ->> 'image'::text AS image, cr.tenant_id AS tenant_id FROM k8s_pods cr, LATERAL jsonb_array_elements(cr.meta->'config'->'containers') AS container WHERE cr.is_active IS NOT FALSE GROUP BY cr.workload_name, cr.workload_type, cr.\"namespace\", cr.cloud_account_id, cr.tenant_id, container ->> 'image'::text ), workload_security_issues as ( SELECT COUNT(DISTINCT cr.workload_name || '-' || cr.\"namespace\") * 1.0 AS workload_namespace_count, r.cloud_account_id as cloud_account_id, r.tenant_id as tenant_id FROM pod_container cr RIGHT OUTER JOIN recommendation r ON r.category = 'Security' AND r.rule_name = 'image_scan' AND r.account_object_id IS NOT NULL AND r.cloud_account_id = cr.cloud_account_id AND r.tenant_id = cr.tenant_id AND r.recommendation->> 'image_name'::text = cr.image WHERE r.severity IN ('Critical', 'High') group by r.cloud_account_id, r.tenant_id )",
                "query": "",
                "range": 7,
                "source": "Recommendation",
                "filters": null,
                "category": "Ops",
                "distinct": "",
                "threshold": 0,
                "unique_id": "17",
                "view_name": "workload_security_issues",
                "grouped_by": ["cloud_account_id", "tenant_id"],
                "range_unit": "DAY",
                "ui_filters": null,
                "subcategory": "",
                "account_column": "cloud_account_id",
                "insight_format": "{} workload has Critical/High security vulnerabilities",
                "aggregate_column": "",
                "resource_id_column_name": ""
              }
            },
