# app (Next.js) local-dev env. Copy to .env and edit as needed.
#   cp app/.env.example app/.env
# Pairs with services-server running from source on http://localhost:8000
# (started via `make run` in api-server/services).

# ---------- NextAuth ----------
# Signs NextAuth session cookies. Generate fresh: openssl rand -base64 32
NEXTAUTH_SECRET=N+vHVMgf0+C678HnyDR9NFBksCz6yH/cIh4mK7hKDro=

