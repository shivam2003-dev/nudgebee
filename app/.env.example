# app (Next.js) local-dev env. Copy to .env and edit as needed.
#   cp app/.env.example app/.env
# Pairs with services-server running from source on http://127.0.0.1:8000
# (started via `make run` in api-server/services).

# ---------- NextAuth ----------
# Signs NextAuth session cookies and the inner session JWT (HS256).
# The value below is a dev-only sentinel: `npm run dev` accepts it (loud
# console warning) so first-time setup works without manual key generation.
# Production refuses to boot with this value or an empty string — rotate
# before deploying: `openssl rand -base64 32`. Rotation impact is small —
# active users just have to sign in again (no encrypted-at-rest data is
# derived from this key).
NEXTAUTH_SECRET=dev-insecure-default-REPLACE-before-prod-openssl-rand-base64-32

# ---------- Secrets (shared with api-server/services/.env) ----------
# MUST be identical to NUDGEBEE_ENCRYPTION_KEY in services-server's .env,
# otherwise the app can't decrypt what services-server writes.
NUDGEBEE_ENCRYPTION_KEY=__REPLACE__

# Shared secret for app↔services-server internal action calls. If set, the
# same value MUST be set as ACTION_API_SERVER_TOKEN in api-server/services/.env.
# When unset, services-server's auth middleware accepts any request — fine
# for local dev, not safe for shared environments. Generate fresh: openssl rand -hex 32
# ACTION_API_SERVER_TOKEN=

# ---------- Local auth ----------
# Built-in any-email/password provider. ON for local dev only — turn OFF in
# any deployment exposed beyond your laptop.
NEXTAUTH_DUMMY_CREDS_ENABLED=true
NEXTAUTH_DUMMY_CREDS_PASSWORD="Test!24#5"

# ---------- Network ----------
BASE_URL=http://127.0.0.1:3000
SERVICE_API_SERVER_URL=http://127.0.0.1:8000
LLM_SERVER_URL=http://127.0.0.1:8005
WORKFLOW_SERVER_URL=http://127.0.0.1:8002
TICKET_SERVICE_URL=http://127.0.0.1:8004
NOTIFICATION_SERVICE_URL=http://127.0.0.1:8003
CLOUD_COLLECTOR_SERVER_URL=http://127.0.0.1:8001
RELAY_SERVER_ENDPOINT=http://127.0.0.1:8006

