# =====================================================================
# App environment configuration. Copy to `.env.local` and fill in values.
# Never commit `.env.local` or any file containing real secrets.
# =====================================================================

# ---------- Relay server (optional; required only if using collector relay) ----------
RELAY_SERVER_ENDPOINT=http://localhost:8080
RELAY_SERVER_SECRET_KEY=change-me-relay-shared-secret

# ---------- Prometheus (optional; for metrics dashboards) ----------
NEXT_PUBLIC_PROMETHEUS_URL=http://localhost:9090

# ---------- Runtime ----------
REACT_APP_NODE_ENV=development
BASE_URL=http://localhost:3000
OTEL_DISABLED=true

# ---------- Google OAuth (optional; required only if Google sign-in enabled) ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------- NextAuth ----------
# Generate with: `openssl rand -base64 32`
NEXTAUTH_SECRET=change-me-nextauth-secret

# RSA private key for signing session JWTs (PEM, newlines escaped as \n).
# Generate with:
#   openssl genrsa -out private.pem 2048
#   awk 'BEGIN{ORS="\\n"} {print}' private.pem
NEXTAUTH_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_YOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----

# 32-byte hex encryption key for at-rest secrets.
# Generate with: `openssl rand -hex 32`
NUDGEBEE_ENCRYPTION_KEY=change-me-32-byte-hex-encryption-key

# ---------- Branding ----------
# Branding is loaded from a JSON theme file at runtime. The default theme
# at `public/branding/default/theme.json` ships with the OSS build. To
# override, drop your own kit into `public/branding/<your-tenant>/` (gitignored
# by default) and point TENANT_BRANDING_FILE at its theme.json.
TENANT_BRANDING_FILE=branding/default/theme.json

# Plain-text title used in email templates (with 'Nudgebee' fallback).
DEFAULT_TITLE=Nudgebee

# Azure AD application (client) ID for the Microsoft Identity Association
# manifest served at /.well-known/microsoft-identity-association.json.
# Leave unset for OSS / dev — the endpoint will return an empty association.
MICROSOFT_IDENTITY_APPLICATION_ID=

# ---------- Local dev login (DO NOT enable in production) ----------
NEXTAUTH_DUMMY_CREDS_ENABLED=false
NEXTAUTH_DUMMY_CREDS_PASSWORD=

# ---------- Commercial license (optional; OSS builds leave disabled) ----------
# Set LICENSE_ENABLED=true and provide NUDGEBEE_LICENSE only if running the
# commercial edition. OSS builds ignore both.
LICENSE_ENABLED=false
NUDGEBEE_LICENSE=

# ---------- Documentation / external links ----------
# Base URL for the public docs site, used by in-app "Learn more" links.
NEXT_PUBLIC_DOCS_URL=https://docs.nudgebee.com

# Public origin of the app, used as a fallback for OAuth redirect URIs and
# email links when BASE_URL is not set. Override per-deployment.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Default Docker image registry shown in the K8s installer. Operators can
# override per-cluster from the UI; this is just the pre-filled default.
NEXT_PUBLIC_DEFAULT_IMAGE_REGISTRY=registry.nudgebee.com

# ---------- Marketplace contact (optional) ----------
MARKETPLACE_CONTACT_EMAIL=

# ---------- AWS Marketplace integration (optional) ----------
AWS_MARKETPLACE_ENABLED=false
AWS_SELLER_ACCESS_KEY=
AWS_SELLER_SECRET_KEY=

# ---------- API tokens for inter-service calls ----------
ACTION_API_SERVER_TOKEN=change-me-action-api-token

# ---------- Annotation prefix for K8s integrations ----------
# Override if you need a different namespace for resource annotations.
NEXT_PUBLIC_ANNOTATION_PREFIX=nudgebee.io
