# ---------- Secrets (shared with api-server/services/.env) ----------
# MUST be identical to NUDGEBEE_ENCRYPTION_KEY in services-server's .env,
# otherwise the app can't decrypt what services-server writes.
NUDGEBEE_ENCRYPTION_KEY=3030303030303030303030303030303030303030303030303030303030303030

# Optional: shared secret for app↔services-server internal action calls.
# Default is empty on both sides, which disables the check (fine for local
# dev). If you set this, the same value MUST be set as ACTION_API_SERVER_TOKEN
# in api-server/services/.env.
# ACTION_API_SERVER_TOKEN=

# ---------- Local auth ----------
# Built-in any-email/password provider. ON for local dev only — turn OFF in
# any deployment exposed beyond your laptop.
NEXTAUTH_DUMMY_CREDS_ENABLED=true
NEXTAUTH_DUMMY_CREDS_PASSWORD="Test!24#5"

# ---------- Network ----------
BASE_URL=http://localhost:3000
SERVICE_API_SERVER_URL=http://localhost:8000
