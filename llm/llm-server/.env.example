# llm-server local-dev env. Copy to .env and edit as needed.
#   cp llm/llm-server/.env.example llm/llm-server/.env
# Values below pair with the default compose stack (docker compose up -d).

# ---------- Runtime ----------
ENV=local
PORT=8000

# ---------- Database ----------
# llm-server uses its own DSN env (LLM_SERVER_DB_URL), not APP_DATABASE_URL.
# Defaults to compose Postgres; reuses the same DB as services-server.
LLM_SERVER_DB_URL=postgresql://postgres:postgrespassword@localhost:5432/nudgebee?sslmode=disable

# ---------- Secrets ----------
# MUST be identical to NUDGEBEE_ENCRYPTION_KEY in api-server/services/.env.
NUDGEBEE_ENCRYPTION_KEY=__REPLACE__

# Optional internal-action token. Default empty on both sides disables the
# check. Set to match api-server/services/.env if you turn it on there.
# ACTION_API_SERVER_TOKEN=

# JWT secret shared with the relay-server's RELAY_WORKSPACE_JWT_SECRET for
# code-analysis workspace authentication. Default is a dev sample.
# LLM_SERVER_JWT_SECRET=

# ---------- LLM provider ----------
# Required to actually serve completions. Pick a provider:
#   google_ai | openai | anthropic | azure_openai | bedrock | ollama | vllm
# Most common for local dev:
LLM_PROVIDER=google_ai
LLM_MODEL_NAME=gemini-2.5-flash-lite
LLM_PROVIDER_API_KEY=
# LLM_PROVIDER_API_ENDPOINT=
# LLM_PROVIDER_API_VERSION=
# LLM_MODEL_FALLBACKS=

# ---------- Network ----------
BASE_URL=http://localhost:3000
SERVICE_API_SERVER_URL=http://localhost:8000
# WORKFLOW_SERVER_URL=http://localhost:8007
# RAG_SERVER_URL=http://localhost:9999
# RELAY_SERVER_ENDPOINT=http://localhost:8004

# ---------- RabbitMQ ----------
# Defaults match the rabbitmq:3-management container in docker-compose.yaml.
RABBIT_MQ_HOST=localhost
RABBIT_MQ_PORT=5672
RABBIT_MQ_USERNAME=guest
RABBIT_MQ_PASSWORD=guest
