    {
      "name": "Document Management",
      "item": [
        {
          "name": "Load Documents",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"module\": \"prometheus\",\n  \"force\": false,\n  \"account_id\": [\"{{account_id}}\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/load_docs",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "load_docs"
              ]
            },
            "description": "Load documents for a specific module or all modules. Modules: prometheus, loki, elastic_search, events, recommendations, planner, rabbitmq, aws, kubectl, postgresql, mysql, github, docs"
          }
        },
        {
          "name": "Load Account Module Documents",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"module\": \"custom_module\",\n  \"account_id\": \"{{account_id}}\",\n  \"data\": \"Document content here\\nLine 2\\nLine 3\",\n  \"format\": \"text\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/load_account_module_docs",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "load_account_module_docs"
              ]
            },
            "description": "Load documents for a specific account and module. Formats: text, json, xml, csv"
          }
        },
        {
          "name": "Delete All Collections",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/delete_collections",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "delete_collections"
              ]
            },
            "description": "Delete all vector collections (use with caution!)"
          }
        }
      ]
    },
    {
      "name": "Search",
      "item": [
        {
          "name": "Get Matching Documents",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"What is CPU usage?\",\n  \"k\": 3,\n  \"account_id\": \"{{account_id}}\",\n  \"module\": \"prometheus\",\n  \"collection_name\": null,\n  \"conversation_id\": \"conv_001\",\n  \"message_id\": \"msg_001\",\n  \"user_id\": \"user_001\",\n  \"agent_id\": \"agent_001\",\n  \"track_token_usage\": true,\n  \"metadata_filter\": null\n}"
            },
            "url": {
              "raw": "{{base_url}}/get_matching_doc",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "get_matching_doc"
              ]
            },
            "description": "Search for matching documents with optional metadata filtering"
          }
        },
        {
          "name": "Get Matching Documents with Metadata Filter",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"What is CPU usage?\",\n  \"k\": 3,\n  \"account_id\": \"{{account_id}}\",\n  \"module\": \"prometheus\",\n  \"conversation_id\": \"conv_001\",\n  \"message_id\": \"msg_001\",\n  \"track_token_usage\": true,\n  \"metadata_filter\": {\n    \"source\": \"docs.example.com\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/get_matching_doc",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "get_matching_doc"
              ]
            },
            "description": "Search with metadata filtering. Example filters: {\"source\": \"value\"}, {\"must\": [{\"field\": \"priority\", \"values\": [\"high\"]}]}"
          }
        },
        {
          "name": "Get Prometheus Matching Documents",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"cpu_usage_percent\",\n  \"k\": 3,\n  \"account_id\": \"{{account_id}}\",\n  \"module\": \"prometheus\",\n  \"conversation_id\": \"conv_001\",\n  \"message_id\": \"msg_001\",\n  \"track_token_usage\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/get_prometheus_matching_doc",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "get_prometheus_matching_doc"
              ]
            },
            "description": "Search for Prometheus metrics with metadata enrichment"
          }
        }
      ]
    },
