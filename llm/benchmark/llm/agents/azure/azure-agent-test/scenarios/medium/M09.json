{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "M09: App Service APPLICATIONINSIGHTS_CONNECTION_STRING points to 'm09-legacy-telemetry' (old decommissioned workspace) instead of 'm09-telemetry' (active workspace). Telemetry appears in wrong/stale workspace. Requires comparing connection string against actual App Insights resources."
  },
  "parameters": {
    "scenarioMode": {
      "type": "string",
      "allowedValues": ["Broken", "Fixed"],
      "defaultValue": "Broken"
    },
    "sharedAppPlanRg": {
      "type": "string",
      "defaultValue": "azure-agent-test-bootstrap"
    }
  },
  "variables": {
    "appName": "[concat('m09app', substring(uniqueString(resourceGroup().id), 0, 8))]",
    "activeAppInsights": "m09-telemetry",
    "legacyAppInsights": "m09-legacy-telemetry"
  },
  "resources": [
    {
      "type": "Microsoft.Insights/components",
      "apiVersion": "2020-02-02",
      "name": "[variables('activeAppInsights')]",
      "location": "[resourceGroup().location]",
      "kind": "web",
      "tags": { "Environment": "production", "Status": "active", "Scenario": "M09" },
      "properties": { "Application_Type": "web", "RetentionInDays": 30 }
    },
    {
      "type": "Microsoft.Insights/components",
      "apiVersion": "2020-02-02",
      "name": "[variables('legacyAppInsights')]",
      "location": "[resourceGroup().location]",
      "kind": "web",
      "tags": { "Environment": "production", "Status": "legacy-decommissioned", "Scenario": "M09" },
      "properties": { "Application_Type": "web", "RetentionInDays": 30 }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2022-03-01",
      "name": "[variables('appName')]",
      "location": "[resourceGroup().location]",
      "kind": "app",
      "dependsOn": [
        "[resourceId('Microsoft.Insights/components', variables('activeAppInsights'))]",
        "[resourceId('Microsoft.Insights/components', variables('legacyAppInsights'))]"
      ],
      "tags": {
        "Name": "m09-backend-api",
        "Environment": "production",
        "Team": "backend",
        "Scenario": "M09",
        "ScenarioMode": "[parameters('scenarioMode')]"
      },
      "properties": {
        "serverFarmId": "[resourceId(parameters('sharedAppPlanRg'), 'Microsoft.Web/serverfarms', 'shared-app-plan')]",
        "siteConfig": {
          "appSettings": [
            {
              "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
              "value": "[if(equals(parameters('scenarioMode'), 'Fixed'), reference(resourceId('Microsoft.Insights/components', variables('activeAppInsights'))).ConnectionString, reference(resourceId('Microsoft.Insights/components', variables('legacyAppInsights'))).ConnectionString)]"
            },
            { "name": "ApplicationInsightsAgent_EXTENSION_VERSION", "value": "~3" },
            { "name": "APP_ENV", "value": "production" }
          ]
        }
      }
    }
  ],
  "outputs": {
    "AppServiceName": { "type": "string", "value": "[variables('appName')]" },
    "ActiveAppInsights": { "type": "string", "value": "[variables('activeAppInsights')]" },
    "LegacyAppInsights": { "type": "string", "value": "[variables('legacyAppInsights')]" },
    "ActiveConnectionString": { "type": "string", "value": "[reference(resourceId('Microsoft.Insights/components', variables('activeAppInsights'))).ConnectionString]" },
    "ConfiguredConnectionString": { "type": "string", "value": "[if(equals(parameters('scenarioMode'), 'Fixed'), reference(resourceId('Microsoft.Insights/components', variables('activeAppInsights'))).ConnectionString, reference(resourceId('Microsoft.Insights/components', variables('legacyAppInsights'))).ConnectionString)]" },
    "BugNote": { "type": "string", "value": "APPLICATIONINSIGHTS_CONNECTION_STRING points to 'm09-legacy-telemetry' - telemetry sent to wrong workspace" },
    "ScenarioMode": { "type": "string", "value": "[parameters('scenarioMode')]" }
  }
}
