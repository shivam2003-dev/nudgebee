{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "E05: App Service identity missing Key Vault Secrets User role. User complaint: Application cannot read secrets from Key Vault, getting 403 Forbidden. Uses shared App Service Plan from bootstrap."
  },
  "parameters": {
    "scenarioMode": {
      "type": "string",
      "allowedValues": ["Broken", "Fixed"],
      "defaultValue": "Broken"
    },
    "sharedAppPlanRg": {
      "type": "string",
      "defaultValue": "azure-agent-test-bootstrap"
    }
  },
  "variables": {
    "appName": "[concat('e05app', substring(uniqueString(resourceGroup().id), 0, 8))]",
    "keyVaultName": "[concat('e05kv', substring(uniqueString(resourceGroup().id), 0, 8))]",
    "keyVaultSecretsUserRoleId": "4633458b-17de-408a-b874-0445c86b69e0",
    "roleAssignmentName": "[guid(resourceGroup().id, 'e05-kv-secrets-user')]"
  },
  "resources": [
    {
      "type": "Microsoft.KeyVault/vaults",
      "apiVersion": "2023-02-01",
      "name": "[variables('keyVaultName')]",
      "location": "[resourceGroup().location]",
      "tags": { "Environment": "production", "Team": "platform", "Scenario": "E05" },
      "properties": {
        "sku": { "family": "A", "name": "standard" },
        "tenantId": "[subscription().tenantId]",
        "enableRbacAuthorization": true,
        "enableSoftDelete": false
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2022-03-01",
      "name": "[variables('appName')]",
      "location": "[resourceGroup().location]",
      "kind": "app",
      "identity": { "type": "SystemAssigned" },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName'))]"
      ],
      "tags": {
        "Name": "e05-config-service",
        "Environment": "production",
        "Scenario": "E05",
        "ScenarioMode": "[parameters('scenarioMode')]"
      },
      "properties": {
        "serverFarmId": "[resourceId(parameters('sharedAppPlanRg'), 'Microsoft.Web/serverfarms', 'shared-app-plan')]",
        "siteConfig": {
          "appSettings": [
            { "name": "KEY_VAULT_URI", "value": "[reference(resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName'))).vaultUri]" },
            { "name": "SECRET_NAME", "value": "database-password" }
          ]
        }
      }
    },
    {
      "condition": "[equals(parameters('scenarioMode'), 'Fixed')]",
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[variables('roleAssignmentName')]",
      "scope": "[concat('Microsoft.KeyVault/vaults/', variables('keyVaultName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', variables('appName'))]",
        "[resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName'))]"
      ],
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('keyVaultSecretsUserRoleId'))]",
        "principalId": "[reference(resourceId('Microsoft.Web/sites', variables('appName')), '2022-03-01', 'Full').identity.principalId]",
        "principalType": "ServicePrincipal"
      }
    }
  ],
  "outputs": {
    "AppServiceName": { "type": "string", "value": "[variables('appName')]" },
    "KeyVaultName": { "type": "string", "value": "[variables('keyVaultName')]" },
    "AppPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Web/sites', variables('appName')), '2022-03-01', 'Full').identity.principalId]"
    },
    "BugNote": { "type": "string", "value": "App Service identity has no Key Vault Secrets User role - secret reads return 403" },
    "ScenarioMode": { "type": "string", "value": "[parameters('scenarioMode')]" }
  }
}
