{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "E01: NSG 'e01-bastion-nsg' has no inbound port 22 rule. User complaint: Cannot SSH into bastion host - connection times out. Root cause: Security group has no allow rule for TCP port 22."
  },
  "parameters": {
    "scenarioMode": {
      "type": "string",
      "allowedValues": ["Broken", "Fixed"],
      "defaultValue": "Broken"
    },
    "sharedAppPlanRg": {
      "type": "string",
      "defaultValue": "azure-agent-test-bootstrap"
    }
  },
  "variables": {
    "brokenRules": [],
    "fixedRules": [
      {
        "name": "AllowSSH",
        "properties": {
          "priority": 100,
          "protocol": "Tcp",
          "access": "Allow",
          "direction": "Inbound",
          "sourceAddressPrefix": "*",
          "sourcePortRange": "*",
          "destinationAddressPrefix": "*",
          "destinationPortRange": "22"
        }
      }
    ],
    "nsgRules": "[if(equals(parameters('scenarioMode'), 'Fixed'), variables('fixedRules'), variables('brokenRules'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2023-04-01",
      "name": "e01-bastion-vnet",
      "location": "[resourceGroup().location]",
      "tags": { "Environment": "production", "Team": "infrastructure", "Scenario": "E01" },
      "properties": {
        "addressSpace": { "addressPrefixes": ["10.0.0.0/16"] }
      }
    },
    {
      "type": "Microsoft.Network/networkSecurityGroups",
      "apiVersion": "2023-04-01",
      "name": "e01-bastion-nsg",
      "location": "[resourceGroup().location]",
      "tags": {
        "Environment": "production",
        "Team": "infrastructure",
        "ScenarioMode": "[parameters('scenarioMode')]"
      },
      "properties": {
        "securityRules": "[variables('nsgRules')]"
      }
    }
  ],
  "outputs": {
    "NsgName": { "type": "string", "value": "e01-bastion-nsg" },
    "SshRuleCount": { "type": "int", "value": "[length(variables('nsgRules'))]" },
    "BugNote": { "type": "string", "value": "NSG e01-bastion-nsg has no inbound port 22 rule - SSH connections timeout" },
    "ScenarioMode": { "type": "string", "value": "[parameters('scenarioMode')]" }
  }
}
