# Core Test Configuration
TEST_ACCOUNT=test_account_id
TEST_USER=test_user_id
TEST_TENANT=test_tenant_id

# LLM Server Connectivity
LLM_SERVER_URL=http://127.0.0.1:8005
APP_DATABASE_URL=postgresql://user:password@127.0.0.1:5432/dbname

# LLM Provider Configuration
LLM_PROVIDER=bedrock
LLM_MODEL_NAME=meta.llama3-1-70b-instruct-v1:0
# LLM_PROVIDER_API_KEY=
# LLM_PROVIDER_API_ENDPOINT=
# LLM_PROVIDER_API_VERSION=
# LLM_PROVIDER_API_TYPE=
# LLM_PROVIDER_REGION=us-west-2

# AWS Configuration (for Bedrock)
AWS_REGION=us-west-2
# aws_access_key_id=
# aws_secret_access_key=

# Embeddings Configuration
EMBEDDINGS_PROVIDER=bedrock
EMBEDDINGS_MODEL_NAME=amazon.titan-embed-text-v2:0
# EMBEDDINGS_PROVIDER_API_ENDPOINT=
# EMBEDDINGS_PROVIDER_API_KEY=
# EMBEDDINGS_PROVIDER_API_VERSION=
# EMBEDDINGS_PROVIDER_REGION=us-west-2

# Email Configuration
EMAIL_SERVER_HOST=smtp.gmail.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=

# General Configuration
MAX_TOKEN_LENGTH=8192
EMBEDDING_BATCH_SIZE=10
MAX_CONCURRENCY=2
MAX_RETRY_COUNT=5
MAX_RETRY_DURATION=600
INITIAL_WAIT_TIME=1

# Authentication — magic-link via notifications-server
# RSA private key shared with NextAuth (PEM format, newlines as \n).
# Used to sign benchmark session JWTs and verify session JWTs from API
# clients. Required.
NEXTAUTH_PRIVATE_KEY=
# Where the benchmark server POSTs the magic-link email (uses the same
# /api/send_email + ``magic_link`` Jinja template the main UI app uses).
# Default: http://notifications:80
# NOTIFICATION_SERVICE_URL=http://127.0.0.1:8003
# Magic-link token TTL in seconds (default 600 = 10 min, mirrors NextAuth).
# MAGIC_LINK_TTL_SECONDS=600
# Per-email cooldown on /auth/email-login in seconds (default 60). Bounds
# mailbox-bombing of a known address.
# EMAIL_LOGIN_COOLDOWN_SEC=60
# Session cookie lifetime in hours (default 24).
# SESSION_MAX_AGE_HOURS=24
# Set to "1" ONLY for local plain-HTTP dev. Production must leave unset
# so the session cookie ships with Secure (no MITM cookie theft).
# BENCHMARK_INSECURE_COOKIES=1
# In-process authz cache TTL in seconds (default 86400 = 24h). Lower
# for faster RBAC propagation, raise for fewer DB queries.
# AUTHZ_CACHE_TTL_SECONDS=86400

# OpenTelemetry Configuration
OTEL_SERVICE_NAME=llm-benchmark-server
# OTEL_TRACES_EXPORTER=otlp,console
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://127.0.0.1:4318/v1/traces
# OTEL_RESOURCE_ATTRIBUTES=service.name=llm-benchmark-server
