# Code Analysis Agent Environment Configuration

# LLM Configuration
LLM_PROVIDER=bedrock
LLM_MODEL=meta.llama3-1-70b-instruct-v1:0
LLM_REGION=us-west-2
LLM_API_KEY=

# GitHub Authentication (required for PR analysis)
GITHUB_TOKEN=your_github_token_here

# Agent Configuration
AGENT_REACT_MAX_ITERATIONS=10
AGENT_REWOO_MAX_ITERATIONS=10
AGENT_MAX_LOG_LINES=50
AGENT_MAX_SEARCH_RESULTS=20

# Analysis Configuration
ANALYSIS_WORKSPACE_DIR=/tmp/code-analysis
ANALYSIS_MAX_PROCESSING_TIME=30m
ANALYSIS_FUZZY_THRESHOLD=0.8
ANALYSIS_MAX_RESULTS=100

# Git Configuration
GIT_CLONE_TIMEOUT=5m
GIT_MAX_REPO_SIZE=536870912
GIT_DEFAULT_BRANCH=main

# GitHub Configuration
GITHUB_BASE_URL=https://api.github.com
GITHUB_TIMEOUT=30s
GITHUB_RETRY_ATTEMPTS=3

# Server Configuration
SERVER_PORT=8080
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s
SERVER_MAX_REQUEST_SIZE=10485760
SERVER_SHUTDOWN_TIMEOUT=30s