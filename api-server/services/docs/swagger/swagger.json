        "/api/webhooks/azure-eventgrid": {
            "post": {
                "description": "Handles the Event Grid validation handshake (`SubscriptionValidationEvent`) and forwards `Microsoft.*` events to the cloud-collector.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "webhooks"
                ],
                "summary": "Azure Event Grid webhook",
                "parameters": [
                    {
                        "description": "Event Grid event array",
                        "name": "payload",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/api.WebhookPayload"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Validation response or relay-success message",
                        "schema": {
                            "$ref": "#/definitions/api.SuccessMessage"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorMessage"
                        }
                    },
                    "502": {
                        "description": "Relay to cloud-collector failed",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorMessage"
                        }
                    }
                }
            }
        },
