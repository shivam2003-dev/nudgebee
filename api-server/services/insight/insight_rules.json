  {
    "unique_id": "17",
    "insight_format": "{} workload has Critical/High security vulnerabilities",
    "type": "Ratio",
    "source": "Recommendation",
    "view_name": "workload_security_issues",
    "with": "WITH pod_containers AS ( SELECT cr.cloud_account_id, cr.tenant_id, cr.workload_name, cr.\"namespace\", container ->> 'image' AS image FROM k8s_pods cr CROSS JOIN LATERAL jsonb_array_elements(cr.meta->'config'->'containers') AS container WHERE cr.is_active IS NOT FALSE AND {{ACCOUNT_FILTER}} ), vulnerable_recommendations AS ( SELECT cloud_account_id, tenant_id, recommendation->>'image_name' AS image_name FROM recommendation WHERE category = 'Security' AND rule_name = 'image_scan' AND account_object_id IS NOT NULL AND severity IN ('Critical', 'High') AND status = 'Open' AND recommendation->>'image_name' IS NOT NULL AND {{ACCOUNT_FILTER}} ), matched_images AS ( SELECT DISTINCT pc.cloud_account_id AS matched_account_id, pc.tenant_id AS matched_tenant_id, pc.image FROM pod_containers pc INNER JOIN vulnerable_recommendations vr ON pc.cloud_account_id = vr.cloud_account_id AND pc.tenant_id = vr.tenant_id AND pc.image = vr.image_name ), workload_security_issues AS ( SELECT COUNT(DISTINCT pc.workload_name || '-' || pc.\"namespace\") * 1.0 AS workload_namespace_count, pc.cloud_account_id, pc.tenant_id FROM pod_containers pc INNER JOIN matched_images mi ON pc.cloud_account_id = mi.matched_account_id AND pc.tenant_id = mi.matched_tenant_id AND pc.image = mi.image GROUP BY pc.cloud_account_id, pc.tenant_id )",
    "grouped_by": [
      "cloud_account_id",
      "tenant_id"
    ],
    "account_column": "cloud_account_id",
    "threshold": 0,
    "category": "Ops",
    "aggregate_column": "max(workload_namespace_count)",
    "severity": "Critical",
    "cloud_providers": ["k8s"]
  },
