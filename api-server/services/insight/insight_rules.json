  {
    "unique_id": "100",
    "insight_format": "Weekly cloud spend: ${}",
    "type": "Ratio",
    "source": "Spends",
    "view_name": "weekly_cost_status",
    "with": "WITH all_accounts AS (\n  SELECT DISTINCT cloud_account AS cloud_account_id, tenant AS tenant_id\n  FROM spends\n  WHERE exclude_aggregate = false\n    AND date >= DATE_TRUNC('week', NOW()) - INTERVAL '1 week'\n),\ncurrent_week AS (\n  SELECT cloud_account AS cloud_account_id, tenant AS tenant_id, SUM(amount) AS current_cost\n  FROM spends\n  WHERE date >= DATE_TRUNC('week', NOW())\n    AND date < DATE_TRUNC('week', NOW()) + INTERVAL '1 week'\n    AND exclude_aggregate = false\n  GROUP BY cloud_account, tenant\n),\nweekly_cost_status AS (\n  SELECT a.cloud_account_id, a.tenant_id,\n    ROUND(GREATEST(COALESCE(cw.current_cost, 0), 0)::numeric, 2) AS current_week_spend\n  FROM all_accounts a\n  LEFT JOIN current_week cw\n    ON a.cloud_account_id = cw.cloud_account_id\n    AND a.tenant_id = cw.tenant_id\n)",
    "grouped_by": [
      "cloud_account_id",
      "tenant_id"
    ],
    "account_column": "cloud_account_id",
    "threshold": -1,
    "category": "Cost",
    "aggregate_column": "MAX(current_week_spend)",
    "severity": "Low",
    "cloud_providers": ["aws", "gcp", "azure"]
  },
