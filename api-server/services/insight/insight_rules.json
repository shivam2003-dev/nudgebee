  {
    "unique_id": "127",
    "insight_format": "{subject_name} is noisiest with {} events this week",
    "type": "Ratio",
    "source": "Event",
    "view_name": "noisy_workloads",
    "with": "WITH noisy_workloads AS ( SELECT subject_name, cloud_account_id, tenant, COUNT(*) AS event_count, ROW_NUMBER() OVER (PARTITION BY cloud_account_id, tenant ORDER BY COUNT(*) DESC) AS rn FROM events WHERE created_at >= NOW() - INTERVAL '7 days' AND subject_name IS NOT NULL AND subject_name != '' GROUP BY subject_name, cloud_account_id, tenant )",
