  {
    "unique_id": "117",
    "insight_format": "Estimated monthly spend: ${}",
    "type": "Ratio",
    "source": "Spends",
    "view_name": "monthly_spend_forecast",
    "with": "WITH all_accounts AS (\n  SELECT DISTINCT cloud_account AS cloud_account_id, tenant AS tenant_id\n  FROM spends\n  WHERE exclude_aggregate = false\n    AND date >= DATE_TRUNC('month', NOW()) - INTERVAL '1 month'\n),\nmonth_to_date AS (\n  SELECT cloud_account AS cloud_account_id, tenant AS tenant_id,\n    SUM(amount) AS mtd_spend,\n    COUNT(DISTINCT DATE(date)) AS days_elapsed\n  FROM spends\n  WHERE date >= DATE_TRUNC('month', NOW())\n    AND exclude_aggregate = false\n  GROUP BY cloud_account, tenant\n),\nmonthly_spend_forecast AS (\n  SELECT a.cloud_account_id, a.tenant_id,\n    ROUND(GREATEST(COALESCE(\n      (mtd.mtd_spend / NULLIF(mtd.days_elapsed, 0) *\n       EXTRACT(DAY FROM (DATE_TRUNC('month', NOW()) + INTERVAL '1 month' - INTERVAL '1 day')::date)),\n      0), 0)::numeric, 2) AS estimated_monthly_spend\n  FROM all_accounts a\n  LEFT JOIN month_to_date mtd\n    ON a.cloud_account_id = mtd.cloud_account_id\n    AND a.tenant_id = mtd.tenant_id\n  WHERE COALESCE(mtd.days_elapsed, 0) >= 1 OR mtd.days_elapsed IS NULL\n)",
    "grouped_by": [
      "cloud_account_id",
      "tenant_id"
    ],
    "account_column": "cloud_account_id",
    "threshold": -1,
    "category": "Cost",
    "aggregate_column": "MAX(estimated_monthly_spend)",
    "severity": "Low",
    "cloud_providers": ["aws", "gcp", "azure"]
  },
