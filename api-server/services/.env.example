# services-server local-dev env. Copy to .env and edit as needed.
#   cp api-server/services/.env.example api-server/services/.env
# Values below pair with the default compose stack (docker compose up -d).

# ---------- Database ----------
# Compose Postgres credentials. Use `localhost` from the host; if you ever run
# services-server inside the compose network, swap @localhost for @postgres.
APP_DATABASE_URL=postgresql://postgres:postgrespassword@localhost:5432/nudgebee?sslmode=disable

# ---------- Secrets (shared with app/.env) ----------
# Encrypts sensitive columns. MUST be identical to NUDGEBEE_ENCRYPTION_KEY in
# app/.env, otherwise the app can't decrypt what services-server writes.
# Rotating it makes previously-encrypted rows unreadable — there is no
# automatic re-encryption migration. Generate fresh: openssl rand -hex 32
NUDGEBEE_ENCRYPTION_KEY=__REPLACE__

# Shared secret for app↔services-server internal action calls. When unset,
# services-server logs a warning at startup and the auth middleware accepts
# any request — fine for local dev, not safe for shared environments. If
# you set this, the same value MUST be set as ACTION_API_SERVER_TOKEN in
# app/.env. Generate fresh: openssl rand -hex 32
# ACTION_API_SERVER_TOKEN=

# ---------- Network ----------
API_PORT=8000
SERVICE_API_SERVER_URL=http://localhost:8000
BASE_URL=http://localhost:3000
ENV=local

# ---------- RabbitMQ ----------
# Defaults match the rabbitmq:3-management container in docker-compose.yaml.
RABBIT_MQ_USERNAME=guest
RABBIT_MQ_PASSWORD=guest
RABBIT_MQ_HOST=localhost
RABBIT_MQ_PORT=5672

# ---------- Cache ----------
# Compose ships a redis:7-alpine — use it instead of in-memory so local
# matches the prod code path.
CACHE_PROVIDER=redis
REDIS_SERVER_HOST=localhost
REDIS_SERVER_PORT=6379
# REDIS_USER_NAME / REDIS_USER_PASSWORD only needed for auth-enabled redis.
