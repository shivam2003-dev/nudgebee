# notifications-server local-dev env. Copy to .env and edit as needed.
#   cp notifications-server/.env.example notifications-server/.env
# Values below pair with the default compose stack (docker compose up -d).
#
# notifications-server uses pydantic-settings; most fields have defaults
# (RabbitMQ host=localhost, Redis host=localhost, Slack/Email empty).
# Only NOTIFICATION_DB_URL is required for boot.

# ---------- Database ----------
# Reuses the compose Postgres. Same DB as services-server / llm-server.
NOTIFICATION_DB_URL=postgresql://postgres:postgrespassword@localhost:5432/nudgebee?sslmode=disable

# ---------- RabbitMQ ----------
# Defaults match the rabbitmq:3-management container in docker-compose.yaml.
RABBIT_MQ_HOST=localhost
RABBIT_MQ_PORT=5672
RABBIT_MQ_USERNAME=guest
RABBIT_MQ_PASSWORD=guest

# ---------- Cache ----------
# Compose ships a redis:7-alpine; use it instead of in_memory so local
# matches the prod code path. Pydantic default for `provider` is in_memory.
CACHE_PROVIDER=redis
REDIS_SERVER_HOST=localhost
REDIS_SERVER_PORT=6379
# REDIS_USER_NAME / REDIS_USER_PASSWORD only needed for auth-enabled redis.

# ---------- Downstream services ----------
# Defaults point at compose service hostnames. Override for from-source dev.
# SERVICE_API_SERVER_URL=http://localhost:8000
# TICKET_SERVICE_URL=http://localhost:8001
# LLM_SERVER_URL=http://localhost:8005
# AUTO_PILOT_URL=http://localhost:9988
# RELAY_SERVER_ENDPOINT=http://localhost:8004
# WORKFLOW_SERVER_URL=http://localhost:8007

# ---------- Notification channels (all optional) ----------
# Email / SMTP — leave empty to disable email sends.
# EMAIL_SERVER_HOST=
# EMAIL_SERVER_PORT=465
# EMAIL_SERVER_USER=
# EMAIL_SERVER_PASSWORD=
# EMAIL_FROM=

# Slack — leave empty to disable Slack notifications.
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
# SLACK_SIGNING_SECRET=
# SLACK_BOT_TOKEN=
# SLACK_CHANNEL_ID=
# SLACK_AUTH_TYPE=

# Public app URL used in email/Slack templates ("View in app" links).
BASE_URL=http://localhost:3000
