# ticket-server local-dev env. Copy to .env and edit as needed.
#   cp ticket-server/.env.example ticket-server/.env
# Values below pair with the default compose stack (docker compose up -d).

# ---------- Runtime ----------
ENV=local
# Must match TICKET_SERVICE_URL port in app/.env.example (http://127.0.0.1:8004).
PORT=8004

# ---------- Database ----------
# Reuses the compose Postgres. Same DSN env services-server uses.
APP_DATABASE_URL=postgresql://postgres:postgrespassword@127.0.0.1:5432/nudgebee?sslmode=disable
NUDGEBEE_DB_SSL_ENABLED=false

# ---------- Secrets ----------
# MUST be identical to NUDGEBEE_ENCRYPTION_KEY in api-server/services/.env.
NUDGEBEE_ENCRYPTION_KEY=__REPLACE__

# Optional internal-action token. Default empty on both sides disables the
# check. Set to match api-server/services/.env if you turn it on there.
# ACTION_API_SERVER_TOKEN=

# ---------- Downstream services ----------
SERVICE_API_SERVER_URL=http://127.0.0.1:8000
# ML_SERVICE_URL=http://127.0.0.1:9999

# ---------- Optional integrations ----------
# GitHub App (only required if testing Jira/GitHub ticket sync)
# GITHUB_APP_ID=
# GITHUB_PRIVATE_KEY=

# OpenAI (only required for ticket auto-categorization features)
# GPT_TOKEN=
# OPENAI_ENDPOINT=https://api.openai.com/v1
# GPT_MODEL=gpt-3.5-turbo

# ---------- Disabled components ----------
# ClickHouse is not part of the OSS local stack.
# Defaults (clickhouse_host=http://127.0.0.1:8123 etc.) are harmless when
# nothing actually queries ClickHouse, but set explicit empty if you want
# to be sure nothing reaches out.
