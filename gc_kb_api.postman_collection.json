		{
			"name": "Global Context (GC) - Tenant-Scoped",
			"item": [
				{
					"name": "Create GC",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const response = pm.response.json();",
									"    if (response.data && response.data.id) {",
									"        pm.collectionVariables.set('gc_id', response.data.id);",
									"        console.log('GC ID saved: ' + response.data.id);",
									"    }",
									"}"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "x-hasura-user-id",
								"value": "{{user_id}}"
							},
							{
								"key": "x-hasura-user-tenant-id",
								"value": "{{tenant_id}}"
							},
							{
								"key": "x-hasura-role",
								"value": "tenant_admin"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"action\": {\n        \"name\": \"ai_create_gc\"\n    },\n    \"input\": {\n        \"request\": {\n            \"global_context\": {\n                \"name\": \"Company_Guidelines\",\n                \"description\": \"Company-wide policies and guidelines\",\n                \"data\": \"Working Hours: 9 AM - 6 PM\\nRemote Work Policy: Hybrid (3 days office, 2 days remote)\\nPTO Policy: 20 days per year\\nCode of Conduct: Professional behavior required\\nSecurity: All devices must have encryption enabled\",\n                \"format\": \"text\",\n                \"file_name\": \"company_guidelines.txt\"\n            }\n        }\n    },\n    \"session_variables\": {\n        \"x-hasura-user-id\": \"{{user_id}}\",\n        \"x-hasura-user-tenant-id\": \"{{tenant_id}}\",\n        \"x-hasura-role\": \"tenant_admin\"\n    }\n}"
						},
						"url": {
